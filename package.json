{
  "name": "buckshot-roulette-solver",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "author": "Pedro Silva",
  "description": "Buckshot Roulette Solver, a fast expectimax assistant that tracks the round and recommends the strongest move.",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run typecheck && npm run build:electron && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.zf4ke.buckshot-roulette-solver",
    "productName": "Buckshot Roulette Solver",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron",
      "dist-renderer",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": ".",
        "filter": ["*.py"]
      }
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "@fontsource/dotgothic16": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@fontsource/space-mono": "^5.2.9",
    "lucide-react": "^0.460.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}
